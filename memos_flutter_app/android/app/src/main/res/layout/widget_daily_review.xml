<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_card_bg"
    android:gravity="start"
    android:orientation="vertical"
    android:padding="14dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/widget_countdown"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="2"
            android:paddingEnd="10dp"
            android:text="@string/widget_daily_review_placeholder_countdown"
            android:textColor="#8A8178"
            android:textSize="10sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/widget_avatar"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:contentDescription="@string/widget_daily_review_label"
            android:scaleType="centerCrop"
            android:src="@mipmap/ic_launcher" />
    </LinearLayout>

    <TextView
        android:id="@+id/widget_excerpt"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_weight="1"
        android:ellipsize="end"
        android:maxLines="6"
        android:text="@string/widget_daily_review_placeholder_body"
        android:textColor="#3B312B"
        android:textSize="14sp"
        android:textStyle="bold" />
</LinearLayout>
